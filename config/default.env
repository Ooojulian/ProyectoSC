# Configuración del Proyecto - Sistemas Complejos

# Nombre del nodo (se sobrescribe por variable de entorno)
NODE_NAME=Node-1

# Tasa de generación de eventos (eventos por segundo)
# Rango: 0.1 a 100
GEN_RATE=1.0

# Tamaño del catálogo de items
# Cantidad de items únicos que pueden generarse
CATALOG_SIZE=10

# Tamaño del payload (bytes adicionales para simular carga)
# 0 = sin carga adicional
# 1000+ = simular datos más pesados
PAYLOAD_SIZE=0

# Probabilidad de pérdida de paquetes (interferencia simulada)
# Rango: 0.0 a 1.0
# 0.0 = sin pérdidas
# 0.2 = 20% de paquetes descartados
DROP_PROB=0.0

# Rutas de archivos
CSV_FILE=/home/julian/ProyectoSC/data/inventory.csv
LOG_FILE=/home/julian/ProyectoSC/logs/sensor.log

# Red Ad-Hoc
ADHOC_SSID=ProyectoSC
ADHOC_CHANNEL=6

# Puerto UDP para broadcast
BROADCAST_PORT=12345

# Configuración del Dashboard
DASHBOARD_PORT=5000
DASHBOARD_HOST=0.0.0.0
